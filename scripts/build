#!/usr/bin/env bash
set -euo pipefail

# Validate and compile the default local device profile from the repo-local venv.
# The profile fetches rtl433_native from a released GitHub ref while keeping deployment-specific
# sensor mappings in the YAML.

cd "$(dirname "$0")/.."

run_preflight=0
update_global=0
firmware_config="${FIRMWARE_CONFIG:-rtl433-esphome-heltec-lora-32-v2.yaml}"
rtl433_esphome_url="${RTL433_ESPHOME_URL:-}"
rtl433_esphome_ref="${RTL433_ESPHOME_REF:-latest}"

usage() {
  echo "Usage: ./scripts/build [--preflight] [--update-global]" >&2
}

latest_release_tag() {
  ./.venv/bin/python -c '
import json
import os
import urllib.request

request = urllib.request.Request(
    "https://api.github.com/repos/Snuffy2/rtl433_esphome/releases/latest",
    headers={"Accept": "application/vnd.github+json"},
)
if token := os.environ.get("GITHUB_TOKEN"):
    request.add_header("Authorization", f"Bearer {token}")
with urllib.request.urlopen(request, timeout=30) as response:
    tag_name = json.load(response)["tag_name"]
print(tag_name)
'
}

resolved_rtl433_esphome_ref() {
  if [[ "${rtl433_esphome_ref,,}" != "latest" ]]; then
    printf '%s\n' "$rtl433_esphome_ref"
    return
  fi

  local latest
  latest="$(latest_release_tag)"
  if [[ -z "$latest" ]]; then
    echo "Could not resolve latest rtl433_esphome release tag." >&2
    exit 1
  fi
  printf '%s\n' "$latest"
}

generated_platformio_ini() {
  local candidate
  local latest=""

  if [[ ! -d .esphome/build ]]; then
    echo "No generated PlatformIO build directory found under .esphome/build." >&2
    exit 1
  fi

  while IFS= read -r candidate; do
    if [[ -z "$latest" || "$candidate" -nt "$latest" ]]; then
      latest="$candidate"
    fi
  done < <(find .esphome/build -mindepth 2 -maxdepth 2 -name platformio.ini -type f -print)

  if [[ -z "$latest" ]]; then
    echo "No generated PlatformIO config found under .esphome/build." >&2
    exit 1
  fi

  printf '%s\n' "$latest"
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --preflight)
      run_preflight=1
      ;;
    --update-global)
      run_preflight=1
      update_global=1
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
  shift
done

if [[ ! -x ./.venv/bin/python ]]; then
  echo "Missing ./.venv/bin/python. Run uv sync --dev first." >&2
  exit 1
fi

resolved_ref="$(resolved_rtl433_esphome_ref)"
esphome_command=(./.venv/bin/python -m esphome)
if [[ -n "$rtl433_esphome_url" ]]; then
  esphome_command+=(-s rtl433_esphome_url "$rtl433_esphome_url")
fi
esphome_command+=(-s rtl433_esphome_ref "$resolved_ref")

"${esphome_command[@]}" config "$firmware_config"

if [[ "$run_preflight" -eq 1 ]]; then
  "${esphome_command[@]}" compile --only-generate "$firmware_config"
  platformio_ini="$(generated_platformio_ini)"

  if [[ "$update_global" -eq 1 ]]; then
    ./scripts/esphome-preflight --update-global "$platformio_ini"
  else
    ./scripts/esphome-preflight "$platformio_ini"
  fi
fi

PLATFORMIO_BUILD_JOBS=1 "${esphome_command[@]}" compile "$firmware_config"
