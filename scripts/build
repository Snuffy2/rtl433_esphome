#!/usr/bin/env bash
set -euo pipefail

# Validate and compile the garage RTL433 ESPHome firmware from the repo-local venv.

cd "$(dirname "$0")/.."

run_preflight=0
update_global=0

usage() {
  echo "Usage: ./scripts/build [--preflight] [--update-global]" >&2
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --preflight)
      run_preflight=1
      ;;
    --update-global)
      run_preflight=1
      update_global=1
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 2
      ;;
  esac
  shift
done

if [[ ! -x ./.venv/bin/python ]]; then
  echo "Missing ./.venv/bin/python. Run uv sync --dev first." >&2
  exit 1
fi

./.venv/bin/python -m esphome config garage-rtl433.yaml

if [[ "$run_preflight" -eq 1 ]]; then
  preflight_args=()
  if [[ "$update_global" -eq 1 ]]; then
    preflight_args+=(--update-global)
  fi
  ./scripts/esphome-preflight "${preflight_args[@]}"
fi

PLATFORMIO_BUILD_JOBS=1 ./.venv/bin/python -m esphome compile garage-rtl433.yaml
