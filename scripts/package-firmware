#!/usr/bin/env bash
set -euo pipefail

# Collect compiled firmware binaries and write the ESP Web Tools manifest.

cd "$(dirname "$0")/.."

usage() {
  echo "Usage: ./scripts/package-firmware <version> <output-dir>" >&2
}

if [[ "$#" -ne 2 ]]; then
  usage
  exit 2
fi

version="$1"
output_dir="$2"
build_name="${FIRMWARE_BUILD_NAME:-rtl433_esphome-heltec_lora_32_v2}"
display_name="${FIRMWARE_DISPLAY_NAME:-rtl433_esphome heltec_lora_32_v2}"
build_env="${FIRMWARE_BUILD_ENV:-rtl433-heltec-lora-32-v2}"

firmware_dir=".esphome/build/$build_env/.pioenvs/$build_env"
if [[ ! -d "$firmware_dir" ]]; then
  printf 'Expected firmware build directory %s. Run FIRMWARE_CONFIG for this profile through ./scripts/build first.\n' "$firmware_dir" >&2
  exit 1
fi

for filename in bootloader.bin firmware.bin firmware.elf firmware.factory.bin firmware.ota.bin partitions.bin; do
  if [[ ! -f "$firmware_dir/$filename" ]]; then
    printf 'Missing firmware output %s/%s. Run ./scripts/build for this profile first.\n' "$firmware_dir" "$filename" >&2
    exit 1
  fi
done

mkdir -p "$output_dir"

copy_output() {
  local source="$1"
  local suffix="$2"

  cp "$firmware_dir/$source" "$output_dir/$build_name$suffix"
}

copy_output bootloader.bin .bootloader.bin
copy_output firmware.bin .bin
copy_output firmware.elf .elf
copy_output firmware.factory.bin .factory.bin
copy_output firmware.ota.bin .ota.bin
copy_output partitions.bin .partitions.bin

checksum() {
  local algorithm="$1"
  local path="$2"

  openssl dgst "-$algorithm" -r "$path" | awk '{print $1}'
}

escaped_version="$(printf '%s' "$version" | sed 's/\\/\\\\/g; s/"/\\"/g')"
escaped_display_name="$(printf '%s' "$display_name" | sed 's/\\/\\\\/g; s/"/\\"/g')"
factory_path="$build_name.factory.bin"
ota_path="$build_name.ota.bin"
factory_md5="$(checksum md5 "$output_dir/$factory_path")"
factory_sha256="$(checksum sha256 "$output_dir/$factory_path")"
ota_md5="$(checksum md5 "$output_dir/$ota_path")"
ota_sha256="$(checksum sha256 "$output_dir/$ota_path")"

cat >"$output_dir/manifest.json" <<EOF
{
  "name": "$escaped_display_name",
  "version": "$escaped_version",
  "home_assistant_domain": "esphome",
  "new_install_prompt_erase": false,
  "builds": [
    {
      "chipFamily": "ESP32",
      "ota": {
        "path": "$ota_path",
        "md5": "$ota_md5",
        "sha256": "$ota_sha256"
      },
      "parts": [
        {
          "path": "$factory_path",
          "offset": 0,
          "md5": "$factory_md5",
          "sha256": "$factory_sha256"
        }
      ]
    }
  ]
}
EOF
