#!/usr/bin/env bash
set -euo pipefail

# Collect compiled firmware binaries and write the ESP Web Tools manifest.

cd "$(dirname "$0")/.."

usage() {
  echo "Usage: ./scripts/package-firmware <version> <output-dir>" >&2
}

if [[ "$#" -ne 2 ]]; then
  usage
  exit 2
fi

version="$1"
output_dir="$2"

firmware_bin="$(find .esphome/build -path '*/.pioenvs/*/firmware.bin' -print | sort)"
firmware_count="$(printf '%s\n' "$firmware_bin" | sed '/^$/d' | wc -l | tr -d ' ')"
if [[ "$firmware_count" -ne 1 ]]; then
  printf 'Expected one firmware.bin, found %s:\n' "$firmware_count" >&2
  printf '%s\n' "$firmware_bin" | sed '/^$/d; s/^/  /' >&2
  exit 1
fi

firmware_dir="$(dirname "$firmware_bin")"
mkdir -p "$output_dir"
cp \
  "$firmware_dir/bootloader.bin" \
  "$firmware_dir/firmware.bin" \
  "$firmware_dir/firmware.elf" \
  "$firmware_dir/firmware.factory.bin" \
  "$firmware_dir/firmware.ota.bin" \
  "$firmware_dir/partitions.bin" \
  "$output_dir/"

checksum() {
  local algorithm="$1"
  local path="$2"

  openssl dgst "-$algorithm" -r "$path" | awk '{print $1}'
}

escaped_version="$(printf '%s' "$version" | sed 's/\\/\\\\/g; s/"/\\"/g')"
factory_md5="$(checksum md5 "$output_dir/firmware.factory.bin")"
factory_sha256="$(checksum sha256 "$output_dir/firmware.factory.bin")"
ota_md5="$(checksum md5 "$output_dir/firmware.ota.bin")"
ota_sha256="$(checksum sha256 "$output_dir/firmware.ota.bin")"

cat >"$output_dir/manifest.json" <<EOF
{
  "name": "Garage RTL433",
  "version": "$escaped_version",
  "home_assistant_domain": "esphome",
  "new_install_prompt_erase": false,
  "builds": [
    {
      "chipFamily": "ESP32",
      "ota": {
        "path": "firmware.ota.bin",
        "md5": "$ota_md5",
        "sha256": "$ota_sha256"
      },
      "parts": [
        {
          "path": "firmware.factory.bin",
          "offset": 0,
          "md5": "$factory_md5",
          "sha256": "$factory_sha256"
        }
      ]
    }
  ]
}
EOF
